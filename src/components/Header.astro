---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Header.astro';
import { buildVersionedPath, DEFAULT_VERSION } from '@/lib/api-versions';

const apiHref = buildVersionedPath(DEFAULT_VERSION.id, '');
---

<Default {...Astro.props}><slot /></Default>

<script define:vars={{ apiHref }}>
  function addHeaderLinks() {
    const rightGroup = document.querySelector('header.header .right-group');
    if (!rightGroup || rightGroup.querySelector('.api-ref-link')) return;

    const link = document.createElement('a');
    link.href = apiHref;
    link.className = 'api-ref-link';
    link.textContent = 'API Reference';
    if (window.location.pathname.startsWith('/api')) {
      link.setAttribute('aria-current', 'true');
    }

    const divider = document.createElement('span');
    divider.className = 'header-divider';
    divider.setAttribute('aria-hidden', 'true');

    // Lead with the nav link, then a divider before the utility icons.
    rightGroup.prepend(divider);
    rightGroup.prepend(link);
  }

  addHeaderLinks();
  document.addEventListener('astro:page-load', addHeaderLinks);
</script>

<style is:global>
  .api-ref-link {
    display: inline-flex;
    align-items: center;
    font-family: 'Fricolage Grotesque', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .api-ref-link:hover,
  .api-ref-link[aria-current='true'] {
    color: var(--sl-color-white);
  }

  .header-divider {
    align-self: center;
    width: 0;
    height: 1.5rem;
    border-inline-end: 1px solid var(--sl-color-gray-6);
  }

  [data-theme='dark'] .header-divider {
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>
