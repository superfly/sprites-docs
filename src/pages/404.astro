---
import '@/styles/custom.css';
---

<html lang="en" data-theme="dark" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Page Not Found | Sprites</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        width: 100%;
        overflow: hidden;
      }

      body {
        font-family: 'Fricolage Grotesque', ui-sans-serif, system-ui,
          -apple-system, BlinkMacSystemFont, sans-serif;
        background: #17141f;
        color: #cdc9da;
      }

      .page {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
      }

      /* Atmospheric background (Sprites analog to fly.io's cityscape) */
      .background {
        position: absolute;
        inset: 0;
        z-index: 0;
        background-color: #17141f;
        background-image: url('/img/cityscape@2x.jpg');
        background-image: -webkit-image-set(
          url('/img/cityscape.jpg') 1x,
          url('/img/cityscape@2x.jpg') 2x
        );
        background-image: image-set(
          url('/img/cityscape.jpg') 1x,
          url('/img/cityscape@2x.jpg') 2x
        );
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
      }

      .background::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(
          130% 105% at 50% 42%,
          transparent 0%,
          rgba(23, 20, 31, 0.2) 55%,
          rgba(23, 20, 31, 0.72) 85%,
          #17141f 100%
        );
        pointer-events: none;
      }

      /* Top-left brand */
      .masthead {
        position: relative;
        z-index: 20;
        display: flex;
        align-items: center;
        height: 6rem;
        padding: 0 clamp(1.25rem, 5vw, 3rem);
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        color: #f3f1fb;
      }

      .logo svg {
        height: 1.75rem;
        width: auto;
        filter: drop-shadow(0 2px 14px rgba(124, 58, 237, 0.55));
      }

      .logo span {
        font-family: 'Mackinac', ui-serif, Georgia, serif;
        font-size: 1.35rem;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      /* Centered content */
      .stage {
        position: relative;
        z-index: 10;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 1.5rem 6rem;
        text-align: center;
      }

      .content {
        width: 100%;
        max-width: 40rem;
        text-shadow: 0 2px 40px rgba(124, 58, 237, 0.35);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        margin-bottom: 1.5rem;
        padding: 0.3rem 0.85rem;
        border-radius: 2rem;
        background: rgba(124, 58, 237, 0.22);
        border: 1px solid rgba(139, 92, 246, 0.35);
        color: #c4b5fd;
        font-family: 'Fragment Mono', ui-monospace, monospace;
        font-size: 0.78rem;
        letter-spacing: 0.06em;
      }

      .content h1 {
        font-family: 'Mackinac', ui-serif, Georgia, serif;
        font-weight: 500;
        font-size: clamp(2rem, 6vw, 3.25rem);
        line-height: 1.08;
        letter-spacing: -0.02em;
        color: #f3f1fb;
        margin-bottom: 1rem;
        text-wrap: balance;
      }

      .content p {
        font-size: 1.075rem;
        line-height: 1.6;
        color: #d9cdec;
        max-width: 34rem;
        margin: 0 auto;
      }

      .content a {
        color: #ffffff;
        font-weight: 500;
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.45);
        text-underline-offset: 2px;
        transition: text-decoration-color 0.15s ease;
      }

      .content a:hover {
        text-decoration-color: #ffffff;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="background"></div>

      <header class="masthead">
        <a href="/" class="logo" aria-label="Sprites docs home">
          <svg width="28" height="28" viewBox="0 0 724 582" fill-rule="evenodd" aria-hidden="true">
            <path d="M205.594 197.898h322.661v108.263H205.594z" fill="#ad47ff"/>
            <path d="M578.582 508.799h-72.323v72.686h72.323v-72.686zm-361.614 0h-72.323v72.686h72.323v-72.686zm361.614-290.742h72.323v145.371h-72.323v72.686h-74.229 1.906v72.685H216.968v-72.685h-72.323v-72.686H72.323V218.057h72.322v-73.163h72.323V72.686h72.323v72.685h144.645V72.686h72.323v72.685h72.323v72.686zM72.323 508.799V363.428H0v145.371h72.323zm650.904 0V363.428h-72.322v145.371h72.322zM289.423 290.742h-.132.132zm-72.455-72.685h72.323v72.685h-72.323v-72.685zm216.968 0h72.323v72.685h-72.323v-72.685zM578.582 0h-72.323v72.686h72.323V0zM216.968 0h-72.323v72.686h72.323V0z" fill="#ad47ff"/>
            <path d="M144.645 363.428V218.057h72.323v-72.686h289.291v72.686h72.323v72.685l-.001.001v72.685h-72.322v72.686h-72.323V508.8H289.291v-72.686h-72.323v-72.686h-72.323zm144.646-72.686h-72.323v-72.685h72.323v72.685zm216.968 0h-72.323v-72.685h72.323v72.685z" fill="#c27bff"/>
            <rect x="216.968" y="218.057" width="72.323" height="72.685" fill="black"/>
            <rect x="433.936" y="218.057" width="72.323" height="72.685" fill="black"/>
          </svg>
          <span>Sprites</span>
        </a>
      </header>

      <main class="stage">
        <div class="content">
          <span class="badge">Error&nbsp;404</span>
          <h1>Well this is embarrassing&hellip;</h1>
          <p>
            The page you&rsquo;re looking for isn&rsquo;t here. Feel free to
            return to the <a href="/">docs home</a> or head to
            <a href="https://sprites.dev">sprites.dev</a> to find what you&nbsp;need.
          </p>
        </div>
      </main>
    </div>
  </body>
</html>
